# ──────────────────────────────────────────────
# Task Planner — deployment environment variables
# Copy to .env and fill in real values.
# ──────────────────────────────────────────────

# Your domain / subdomain (must have a DNS A record pointing to your server)
SITE_ADDRESS=tasks.example.com

# PostgreSQL credentials
POSTGRES_USER=taskplanner
POSTGRES_PASSWORD=CHANGE_ME_to_a_strong_random_password
POSTGRES_DB=taskplanner

# HTTP Basic Auth — protects the whole app at the proxy level
# Username shown in the browser login prompt:
AUTH_USER=admin
# Generate the bcrypt hash:  docker run --rm caddy:2-alpine caddy hash-password
# Paste the output here (keep the dollar signs):
AUTH_PASS_HASH=$2a$14$REPLACE_ME
